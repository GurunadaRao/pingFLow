# ============================================================================
# VibeChat Environment Variables — Sprint 0 Template
# ============================================================================
# Copy this file to `.env.local` and fill in all credentials
# NEVER commit `.env.local` to git (already in .gitignore)
# ============================================================================

# ────────────────────────────────────────────────────────────────────────
# TIER 1: PostgreSQL (Relational Metadata) — Prisma ORM
# ────────────────────────────────────────────────────────────────────────
# Provider: Supabase (https://supabase.com) — PostgreSQL 16 managed
# Format: postgresql://user:password@host:port/database
# Get from Supabase Dashboard → Settings → Database → Connection string (URI)

DATABASE_URL=postgresql://postgres.xxxx:password@db.xxxx.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────────────────
# TIER 2: MongoDB (Message History, Bucket Pattern) — Mongoose
# ────────────────────────────────────────────────────────────────────────
# Provider: MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
# Format: mongodb+srv://user:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# Note: Username and password must be URL-encoded

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vibechat?retryWrites=true&w=majority

# ────────────────────────────────────────────────────────────────────────
# TIER 3: Redis (Ephemeral State, Pub/Sub, Cache) — ioredis
# ────────────────────────────────────────────────────────────────────────
# Provider: Upstash (https://upstash.com) or self-hosted Docker
# Format: redis://[:password]@host:port or redis://default:password@host:port
# Example (Upstash): redis://default:xyz@us1-xxx.upstash.io:34567
# Example (Local): redis://localhost:6379

REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────────────────
# TIER 4: Media Storage & CDN (Images/Videos) — Cloudinary
# ────────────────────────────────────────────────────────────────────────
# Provider: Cloudinary (https://cloudinary.com)
# Get credentials: Dashboard → Settings → API Keys
# CLOUDINARY_CLOUD_NAME: Account name (e.g., "vibechat-dev")
# CLOUDINARY_API_KEY: Public API key (e.g., "123456789")
# CLOUDINARY_API_SECRET: Secret API key (keep confidential!)

CLOUDINARY_CLOUD_NAME=duvr3z2z0
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ────────────────────────────────────────────────────────────────────────
# Authentication: JWT & Refresh Tokens
# ────────────────────────────────────────────────────────────────────────
# Generate secrets: openssl rand -base64 32
# DO NOT use the same secret for JWT and refresh token

JWT_SECRET=replace-with-strong-random-secret-32-chars-minimum
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-another-strong-random-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# ────────────────────────────────────────────────────────────────────────
# Server Configuration
# ────────────────────────────────────────────────────────────────────────

PORT=4000
NODE_ENV=development
API_VERSION=v1
LOG_LEVEL=debug

# ────────────────────────────────────────────────────────────────────────
# Client Configuration (Frontend .env.local)
# ────────────────────────────────────────────────────────────────────────

VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000

# ────────────────────────────────────────────────────────────────────────
# Email Service (Transactional) — Resend
# ────────────────────────────────────────────────────────────────────────
# Sign up: https://resend.com
# Get API key: https://resend.com/api-tokens

RESEND_API_KEY=re_xxx...

# ────────────────────────────────────────────────────────────────────────
# Webhooks & Automation — n8n
# ────────────────────────────────────────────────────────────────────────
# Base URL for n8n webhooks (deployed n8n instance)
# Example (Cloud): https://yourinstance.n8n.cloud/
# Example (Self-hosted): http://localhost:5678

N8N_WEBHOOK_BASE_URL=http://localhost:5678/

# ────────────────────────────────────────────────────────────────────────
# Error Tracking & Monitoring — Sentry (Sprint 7+)
# ────────────────────────────────────────────────────────────────────────
# Sign up: https://sentry.io
# Get DSN: https://sentry.io/settings/projects/[project]/keys/

SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/123456



# ────────────────────────────────────────────────────────────────────────
# CORS & Security
# ────────────────────────────────────────────────────────────────────────

CORS_ORIGIN=http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ────────────────────────────────────────────────────────────────────────
# Rate Limiting (Redis-backed)
# ────────────────────────────────────────────────────────────────────────

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ────────────────────────────────────────────────────────────────────────
# Feature Flags (Sprint 7+)
# ────────────────────────────────────────────────────────────────────────

FEATURE_E2EE=false
FEATURE_SEARCH=false
FEATURE_VOICE_CALLS=false
FEATURE_VIDEO_CALLS=false
