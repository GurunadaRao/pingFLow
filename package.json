{
  "name": "@pingflow/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "PingFlow Open-source chat application monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"client,server\" -c \"cyan,green\" \"npm run dev -w @pingflow/client\" \"npm run dev -w @pingflow/server\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
